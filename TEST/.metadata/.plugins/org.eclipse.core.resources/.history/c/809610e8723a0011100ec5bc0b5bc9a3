/**
  * @brief This function handles USART1 global interrupt.
  */
void USART1_IRQHandler(void)
{
  /* USER CODE BEGIN USART1_IRQn 0 */
  
  /* USER CODE END USART1_IRQn 0 */
  HAL_UART_IRQHandler(&huart1);
  /* USER CODE BEGIN USART1_IRQn 1 */
  if(__HAL_UART_GET_FLAG(&huart1, UART_FLAG_IDLE)!=RESET){
     __HAL_UART_CLEAR_IDLEFLAG(&huart1);//清除IDLE中断标志位
     HAL_UART_DMAStop(&huart1);//停止DMA传输
     //比对数据与预设数据包是否一致，若一致则执行相应操作} 

    uint16_t received_length = 256 - __HAL_DMA_GET_COUNTER(&hdma_usart1_rx);//计算实际接收的数据长度

  if(received_length == 4 && uart1_rx_buf[0]==0xAA&&uart1_rx_buf[1]==0xBB&&uart1_rx_buf[2]==0xCC&&uart1_rx_buf[3]==0xDD)
    {
      tx_busy = 1; // 标记发送忙
      HAL_UART_Transmit_DMA(&huart1,SUCCESS_MSG, sizeof(SUCCESS_MSG)-1);//发送success
    }
    else
    {
      //数据包不匹配，立即重新开启DMA接收
       memset(uart1_rx_buf, 0, sizeof(uart1_rx_buf));//清空接收缓冲区
    HAL_UART_Receive_DMA(&huart1, uart1_rx_buf, 256);//重新开启DMA接收
    }
   if(!tx_busy)
   {
     memset(uart1_rx_buf, 0, sizeof(uart1_rx_buf));//清空接收缓冲区
   }
  }
}
  /* USER CODE END USART1_IRQn 1 */
}

/* USER CODE BEGIN 1 */
void HAL_UART_TxCpltCallback(UART_HandleTypeDef *huart)
{
    if (huart->Instance == USART1) {
        tx_busy = 0;
        memset(uart1_rx_buf, 0, sizeof(uart1_rx_buf));
        HAL_UART_Receive_DMA(&huart1, uart1_rx_buf, 256);  // 发送完毕后才重启接收
    }
}
/* USER CODE END 1 */
